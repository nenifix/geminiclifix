# Required
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id

# Model provider (pick one)
# Option A: OpenRouter (default)
OPENROUTER_API_KEY=sk-or-...here
MODEL=openrouter/owl-alpha

# Option B: Ollama (local) — uncomment MODEL_BASE_URL + MODEL, comment out OPENROUTER_API_KEY
# MODEL_BASE_URL=http://localhost:11434/v1
# MODEL=llama3

# Option C: LM Studio (local) — uncomment MODEL_BASE_URL + MODEL, comment out OPENROUTER_API_KEY
# MODEL_BASE_URL=http://localhost:1234/v1
# MODEL=local-model

# Optional
WORKSPACE=./workspace
MAX_CONTEXT_MESSAGES=20

# ── Integrations (optional) ───────────────────────────

# Notion (https://notion.so/my-integrations)
NOTION_API_KEY=ntn_your_key_here

# Zapier (https://zapier.com/app/developer)
ZAPIER_API_KEY=your_zapier_api_key
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your-webhook-id

# Task logging
TASK_LOG_DIR=./logs

# ── Browser (optional) ─────────────────────────────────
# Path to Chrome/Chromium executable (auto-detected if not set)
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:   /usr/bin/google-chrome
CHROME_PATH=
